# ════════════════════════════════════════════════════════════════
# HuggingClaw Configuration
# Copy to .env for local dev. For HF Spaces, add as Secrets.
# ════════════════════════════════════════════════════════════════

# ── REQUIRED ─────────────────────────────────────────────────

# Your LLM provider API key
#   Anthropic: sk-ant-v0-...
#   OpenAI: sk-...
#   Google: AIzaSy...
LLM_API_KEY=your_api_key_here

# Gateway authentication token
# Generate: openssl rand -hex 32
GATEWAY_TOKEN=your_gateway_token_here

# ── LLM CONFIGURATION ───────────────────────────────────────

# Provider: anthropic, openai, google
LLM_PROVIDER=anthropic

# Model ID (provider-specific)
#   Anthropic: anthropic/claude-opus-4-6, anthropic/claude-sonnet-4-5, anthropic/claude-haiku-4-5
#   OpenAI: gpt-4, gpt-4-turbo, gpt-3.5-turbo
#   Google: gemini-pro, gemini-pro-vision
LLM_MODEL=anthropic/claude-haiku-4-5

# ── TELEGRAM ─────────────────────────────────────────────────

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Single user ID (simple setup)
TELEGRAM_USER_ID=

# Multiple user IDs, comma-separated (for teams/families)
# If set, overrides TELEGRAM_USER_ID
# TELEGRAM_USER_IDS=123456789,987654321,555555555

# ── WORKSPACE PERSISTENCE ────────────────────────────────────

# Your HuggingFace username
HF_USERNAME=

# HuggingFace token (needs write access)
# Get one: https://huggingface.co/settings/tokens
HF_TOKEN=

# Dataset name for backup (default: huggingclaw-backup)
# Auto-created if it doesn't exist!
# BACKUP_DATASET_NAME=huggingclaw-backup

# Git commit metadata
# WORKSPACE_GIT_USER=openclaw@example.com
# WORKSPACE_GIT_NAME=OpenClaw Bot

# ── AUTO-SYNC ────────────────────────────────────────────────

# Workspace sync interval in seconds (default: 600 = 10 min)
# Automatically commits + pushes workspace changes
# SYNC_INTERVAL=600

# ── KEEP-ALIVE ───────────────────────────────────────────────

# Self-ping interval in seconds (default: 300 = 5 min)
# Prevents HF Spaces 48h inactivity sleep
# Set to 0 to disable
# KEEP_ALIVE_INTERVAL=300

# ── ADVANCED ─────────────────────────────────────────────────

# OpenClaw version (default: latest)
# Pin to a specific version for stability
# OPENCLAW_VERSION=latest

# Health server port (default: 7861)
# HEALTH_PORT=7861
